{
  "name": "tandem-desktop",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "build": "pnpm --filter @tandem/shared build && pnpm --filter @tandem/client build",
    "dev": "pnpm --filter @tandem/shared build && node scripts/dev.mjs",
    "dev:client": "pnpm --filter @tandem/shared build && node scripts/dev.mjs",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
