{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tandem",
  "version": "1.1.5",
  "identifier": "casa.tafu.tandem",
  "build": {
    "beforeDevCommand": "pnpm dev:vite",
    "devUrl": "http://127.0.0.1:3842",
    "beforeBuildCommand": "pnpm build:vite",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tandem",
        "width": 1280,
        "height": 800,
        "fullscreen": false,
        "resizable": true,
        "additionalBrowserArgs": "--disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection --disable-background-timer-throttling --disable-renderer-backgrounding --disable-backgrounding-occluded-windows"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' http://127.0.0.1:* http://localhost:* http://tauri.localhost data: blob:; media-src 'self' blob: mediastream:; connect-src 'self' http://127.0.0.1:* http://localhost:* http://tauri.localhost ws://127.0.0.1:* ws://localhost:* https: wss:; style-src 'self' 'unsafe-inline'; font-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "appimage"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
